# Firmware dumps — potentially copyrighted ROM/EEPROM contents
dumps/

# SDCC build artifacts (regenerated by make)
*.rel
*.rst
*.sym
*.map
*.mem
*.lk
*.noi
*.lst
*.ihx
*.asm
!crt0_*.asm
!disasm.asm

# Compiled binaries (regenerated by make)
*/eeprom/eeprom_fw.bin
*/eeprom/eeprom_image.bin
*/eeprom/code.bin

# Ghidra project files (large, regenerated by headless scripts)
ghidra_project/

# Python bytecode
__pycache__/
*.pyc

# Cloned external repos (fetched separately)
tools/ms-tools
tools/MacroSilicon
tools/macrosilicon_ms2107_research

# ROM decompilation/disassembly (regenerated by Ghidra scripts, and
# derived from copyrighted ROM dumps)
*/rom/decompiled.c
*/rom/disasm.asm
*/rom/*.bin
*/rom/code_page_*.bin

# Datasheets (copyrighted)
docs/*.pdf

# Zone identifiers (Windows artifacts)
*.Zone.Identifier
